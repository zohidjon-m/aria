{
  "$defs": {
    "SubjectRef": {
      "additionalProperties": false,
      "properties": {
        "alert_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Alert Id"
        },
        "case_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Case Id"
        },
        "customer_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Customer Id"
        }
      },
      "title": "SubjectRef",
      "type": "object"
    },
    "ToolExecutionScope": {
      "additionalProperties": false,
      "properties": {
        "allowed_account_ids": {
          "items": {
            "type": "integer"
          },
          "title": "Allowed Account Ids",
          "type": "array"
        },
        "allowed_case_ids": {
          "items": {
            "type": "integer"
          },
          "title": "Allowed Case Ids",
          "type": "array"
        },
        "allowed_customer_ids": {
          "items": {
            "type": "integer"
          },
          "title": "Allowed Customer Ids",
          "type": "array"
        },
        "allowed_transaction_ids": {
          "items": {
            "type": "integer"
          },
          "title": "Allowed Transaction Ids",
          "type": "array"
        }
      },
      "title": "ToolExecutionScope",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "agent_run_id": {
      "minLength": 1,
      "title": "Agent Run Id",
      "type": "string"
    },
    "correlation_id": {
      "minLength": 1,
      "title": "Correlation Id",
      "type": "string"
    },
    "idempotency_key": {
      "minLength": 1,
      "title": "Idempotency Key",
      "type": "string"
    },
    "officer_id": {
      "minLength": 1,
      "title": "Officer Id",
      "type": "string"
    },
    "purpose": {
      "enum": [
        "triage",
        "investigation",
        "risk_scoring",
        "sar_drafting",
        "evaluation"
      ],
      "title": "Purpose",
      "type": "string"
    },
    "scope": {
      "$ref": "#/$defs/ToolExecutionScope"
    },
    "subject": {
      "$ref": "#/$defs/SubjectRef"
    },
    "tenant_id": {
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "tool_args": {
      "additionalProperties": true,
      "title": "Tool Args",
      "type": "object"
    }
  },
  "required": [
    "tenant_id",
    "officer_id",
    "agent_run_id",
    "purpose",
    "subject",
    "scope",
    "idempotency_key",
    "correlation_id"
  ],
  "title": "MCPRequestEnvelope",
  "type": "object"
}
