{
  "$defs": {
    "DataCompleteness": {
      "additionalProperties": false,
      "properties": {
        "complete": {
          "default": true,
          "title": "Complete",
          "type": "boolean"
        },
        "lookback_days_available": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lookback Days Available"
        },
        "lookback_days_requested": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lookback Days Requested"
        },
        "missing_segments": {
          "items": {
            "type": "string"
          },
          "title": "Missing Segments",
          "type": "array"
        },
        "rows_requested": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rows Requested"
        },
        "rows_returned": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rows Returned"
        }
      },
      "title": "DataCompleteness",
      "type": "object"
    },
    "MCPSourceRef": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "minLength": 1,
          "title": "Entity Id",
          "type": "string"
        },
        "entity_type": {
          "minLength": 1,
          "title": "Entity Type",
          "type": "string"
        },
        "field_names": {
          "items": {
            "type": "string"
          },
          "title": "Field Names",
          "type": "array"
        },
        "retrieved_at": {
          "minLength": 1,
          "title": "Retrieved At",
          "type": "string"
        },
        "source_system": {
          "default": "bank_mcp",
          "title": "Source System",
          "type": "string"
        }
      },
      "required": [
        "entity_type",
        "entity_id",
        "retrieved_at"
      ],
      "title": "MCPSourceRef",
      "type": "object"
    },
    "Phase3AuditEvent": {
      "additionalProperties": false,
      "properties": {
        "agent_run_id": {
          "minLength": 1,
          "title": "Agent Run Id",
          "type": "string"
        },
        "audit_id": {
          "minLength": 1,
          "title": "Audit Id",
          "type": "string"
        },
        "correlation_id": {
          "minLength": 1,
          "title": "Correlation Id",
          "type": "string"
        },
        "created_at": {
          "minLength": 1,
          "title": "Created At",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        },
        "idempotency_key": {
          "minLength": 1,
          "title": "Idempotency Key",
          "type": "string"
        },
        "officer_id": {
          "minLength": 1,
          "title": "Officer Id",
          "type": "string"
        },
        "outcome": {
          "enum": [
            "success",
            "denial",
            "partial_response",
            "error"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "policy_decisions": {
          "items": {
            "$ref": "#/$defs/Phase3PolicyDecision"
          },
          "title": "Policy Decisions",
          "type": "array"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/MCPSourceRef"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "status": {
          "enum": [
            "ok",
            "partial",
            "denied",
            "error"
          ],
          "title": "Status",
          "type": "string"
        },
        "tenant_id": {
          "minLength": 1,
          "title": "Tenant Id",
          "type": "string"
        },
        "tool_category": {
          "enum": [
            "read",
            "bank_write",
            "sidecar_write",
            "sidecar_proposal"
          ],
          "title": "Tool Category",
          "type": "string"
        },
        "tool_name": {
          "minLength": 1,
          "title": "Tool Name",
          "type": "string"
        }
      },
      "required": [
        "audit_id",
        "correlation_id",
        "tenant_id",
        "officer_id",
        "agent_run_id",
        "tool_name",
        "tool_category",
        "outcome",
        "status",
        "idempotency_key",
        "created_at"
      ],
      "title": "Phase3AuditEvent",
      "type": "object"
    },
    "Phase3PolicyDecision": {
      "additionalProperties": false,
      "properties": {
        "decision": {
          "enum": [
            "allow",
            "deny",
            "limit",
            "audit",
            "requires_human_review"
          ],
          "title": "Decision",
          "type": "string"
        },
        "decision_source": {
          "enum": [
            "scope_policy",
            "rbac",
            "runtime_policy",
            "bank_mcp",
            "sidecar_policy"
          ],
          "title": "Decision Source",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        },
        "granted_permissions": {
          "items": {
            "enum": [
              "can_view_alerts",
              "can_manage_cases",
              "can_file_sar",
              "can_manage_rules",
              "can_manage_users",
              "service_identity"
            ],
            "type": "string"
          },
          "title": "Granted Permissions",
          "type": "array"
        },
        "missing_permissions": {
          "items": {
            "enum": [
              "can_view_alerts",
              "can_manage_cases",
              "can_file_sar",
              "can_manage_rules",
              "can_manage_users",
              "service_identity"
            ],
            "type": "string"
          },
          "title": "Missing Permissions",
          "type": "array"
        },
        "policy": {
          "minLength": 1,
          "title": "Policy",
          "type": "string"
        },
        "reason": {
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "required_permissions": {
          "items": {
            "enum": [
              "can_view_alerts",
              "can_manage_cases",
              "can_file_sar",
              "can_manage_rules",
              "can_manage_users",
              "service_identity"
            ],
            "type": "string"
          },
          "title": "Required Permissions",
          "type": "array"
        }
      },
      "required": [
        "decision",
        "decision_source",
        "policy",
        "reason"
      ],
      "title": "Phase3PolicyDecision",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "audit_event": {
      "$ref": "#/$defs/Phase3AuditEvent"
    },
    "data_completeness": {
      "$ref": "#/$defs/DataCompleteness"
    },
    "facts": {
      "additionalProperties": true,
      "title": "Facts",
      "type": "object"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "policy_decisions": {
      "items": {
        "$ref": "#/$defs/Phase3PolicyDecision"
      },
      "title": "Policy Decisions",
      "type": "array"
    },
    "source_refs": {
      "items": {
        "$ref": "#/$defs/MCPSourceRef"
      },
      "title": "Source Refs",
      "type": "array"
    },
    "status": {
      "enum": [
        "ok",
        "partial",
        "denied",
        "error"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "status",
    "audit_event"
  ],
  "title": "Phase3MCPResponseEnvelope",
  "type": "object"
}
